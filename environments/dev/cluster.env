# environments/dev/cluster.env
# Non-secret cluster parameters for the talos-omni-backbase-dev environment.
# This file is committed to Git. It does NOT contain credentials or tokens.
# Secret inputs (kubeconfig, Isovalent credentials) belong in .env (git-ignored).
#
# Author: Julio Garcia

# ─── Azure ───────────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_NAME="EB Azure Training"
AZURE_SUBSCRIPTION_ID="086f0c8c-d41c-4e07-94a3-e3b56a41059d"
AZURE_REGION="eastus"
AZURE_RESOURCE_GROUP="base-dojo-rg"
AZURE_VNET_NAME="talos-vnet"
AZURE_VNET_CIDR="10.0.0.0/16"
AZURE_CP_SUBNET_NAME="controlplane-subnet"
AZURE_CP_SUBNET_CIDR="10.0.1.0/24"
AZURE_WORKER_SUBNET_NAME="worker-subnet"
AZURE_WORKER_SUBNET_CIDR="10.0.2.0/24"
AZURE_LB_NAME="talos-lb"
AZURE_LB_IP_RESOURCE="talos-lb-ip"

# ─── Cluster ─────────────────────────────────────────────────────────────────
CLUSTER_NAME="talos-omni-backbase-dev"
CLUSTER_API_ENDPOINT="20.120.8.75"
CLUSTER_API_PORT="6443"

# ─── Omni ────────────────────────────────────────────────────────────────────
OMNI_INSTANCE="bellyupdown"
OMNI_URL="https://bellyupdown.na-west-1.omni.siderolabs.io/clusters"

# ─── Networking ──────────────────────────────────────────────────────────────
POD_CIDR="10.244.0.0/16"
SERVICE_CIDR="10.96.0.0/12"

# ─── Isovalent Enterprise ────────────────────────────────────────────────────
ISOVALENT_PLATFORM_VERSION="v25.11"
ISOVALENT_HELM_REPO="https://helm.isovalent.com"
ISOVALENT_HELM_CHART="isovalent/cilium"
HELM_RELEASE="cilium"
HELM_NAMESPACE="kube-system"
# ISOVALENT_VERSION is intentionally not set here — it is set in .env
# because it pinpoints the exact chart version which changes on upgrade.
# Populate ISOVALENT_VERSION in .env before running make install or make upgrade.
