# .env.example — operator input template for azure-talos-omni-backbase-dev
# Copy this file to .env and populate all required values.
# .env is git-ignored and must never be committed.
#
# Author: Julio Garcia

# ─── Cluster access ───────────────────────────────────────────────────────────
# kubeconfig downloaded from Omni:
#   https://bellyupdown.na-west-1.omni.siderolabs.io/clusters → talos-omni-backbase-dev → Download kubeconfig
KUBECONFIG=/path/to/talos-omni-backbase-dev-kubeconfig.yaml

# ─── Cluster parameters ───────────────────────────────────────────────────────
# These match the autodiscovered values in environments/dev/cluster.env
# Override here only if your local setup differs.
CLUSTER_API_ENDPOINT=20.120.8.75
CLUSTER_API_PORT=6443
CLUSTER_NAME=talos-omni-backbase-dev

# ─── Isovalent Enterprise Helm repository ─────────────────────────────────────
# Confirm the repo URL and authentication requirements from your Isovalent
# customer portal before populating these values.
# If the repo is publicly accessible, leave USERNAME and TOKEN blank.
ISOVALENT_HELM_REPO=https://helm.isovalent.com
ISOVALENT_HELM_USERNAME=
ISOVALENT_HELM_TOKEN=

# ─── Isovalent Enterprise version ─────────────────────────────────────────────
# Set to the exact chart version for Isovalent Enterprise Platform v25.11.
# Confirm the chart version from your Isovalent customer portal or release notes.
ISOVALENT_VERSION=

# ─── Isovalent Enterprise license (if required) ───────────────────────────────
# Some Isovalent Enterprise deployments require a license key supplied as a
# Kubernetes secret or Helm value. Confirm from your customer portal.
# Leave blank if not required.
ISOVALENT_LICENSE_KEY=
