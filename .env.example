# .env.example — operator input template for azure-talos-omni-backbase-dev
# Copy this file to .env and populate KUBECONFIG at minimum.
# .env is git-ignored and must never be committed.
#
# The Isovalent Helm repo (https://helm.isovalent.com) is publicly accessible.
# No credentials are required to install the chart.
#
# Author: Julio Garcia

# ─── REQUIRED ─────────────────────────────────────────────────────────────────
# kubeconfig downloaded from Omni:
#   https://bellyupdown.na-west-1.omni.siderolabs.io/clusters
#   → talos-omni-backbase-dev → Download kubeconfig
KUBECONFIG=/path/to/talos-omni-backbase-dev-kubeconfig.yaml

# ─── OPTIONAL: Override cluster defaults ─────────────────────────────────────
# These are already set correctly for this environment.
# Only override if your local setup differs from the known values.
#CLUSTER_API_ENDPOINT=20.120.8.75
#CLUSTER_API_PORT=6443
#CLUSTER_NAME=talos-omni-backbase-dev

# ─── OPTIONAL: Pin chart version ─────────────────────────────────────────────
# If not set, install-cilium.sh auto-discovers the latest stable chart version.
# Run `make discover-version` to see available versions, then pin here.
# Recommended: pin to a specific version before production use.
#
# To use the enterprise-specific chart (older releases up to ~1.17.x era):
#HELM_CHART=isovalent/cilium-enterprise
#ISOVALENT_VERSION=1.17.7
#
# To use the unified chart (newer releases, 1.17.8+ and 1.18.x):
#HELM_CHART=isovalent/cilium
#ISOVALENT_VERSION=1.17.9

# ─── OPTIONAL: Enterprise credentials ────────────────────────────────────────
# The Isovalent Helm repo is public. Credentials are not needed for repo access.
# If you have enterprise-only image pull credentials or a license key from your
# Isovalent customer account, set them here.
#ISOVALENT_LICENSE_KEY=
